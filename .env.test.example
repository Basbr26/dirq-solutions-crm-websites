# E2E Test Environment Variables
# Copy this file to .env.test and fill in the values
# .env.test is gitignored - NEVER commit it

# Supabase (same as .env.local)
VITE_SUPABASE_URL=https://pdqdrdddgbiiktcwdslv.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Service role key (for test data factory - has full DB access)
# Zoek deze in: Supabase Dashboard > Project Settings > API > service_role
TEST_SUPABASE_SERVICE_KEY=<your-service-role-key>

# Test account credentials (maak een apart account aan met SALES of ADMIN rol)
# GEBRUIK NIET het echte admin account!
TEST_USER_EMAIL=e2e-test@yourdomain.com
TEST_USER_PASSWORD=StrongTestPassword123!

# Google (same as .env.local - needed for Vite build)
VITE_GOOGLE_CLIENT_ID=<your-google-client-id>
VITE_GOOGLE_API_KEY=<your-google-api-key>
VITE_GOOGLE_REDIRECT_URI=http://localhost:8080
